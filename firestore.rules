rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write their own synced data --
    // everything else is denied by default. See cloud-sync.js: each
    // localStorage key becomes one doc at users/{uid}/kv/{encodedKey}.
    match /users/{userId}/kv/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Group Study (Kahoot-style live sessions). Both hosts and joining
    // players use Firebase Anonymous Auth (silent, no popup, no Google
    // account needed to join per product decision) purely so there's a
    // stable uid these rules can check -- state itself is readable by
    // anyone with the room code (no login wall to even watch), but only
    // the host can advance game state, and each player can only write
    // their own player doc (their own nickname/score/answers).
    match /gameRooms/{roomCode} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.hostUid == request.auth.uid;
      allow delete: if false;

      match /players/{playerId} {
        allow read: if true;
        allow create, update: if request.auth != null && request.auth.uid == playerId;
        allow delete: if false;
      }
    }

    // "Who's studying now" (presence.js). Each doc is just a heartbeat
    // timestamp under the viewer's own uid -- no name, no note content, no
    // sign of *who* specifically, so an open read is no different in kind
    // from gameRooms' own open read above. Only the owning uid can write
    // (or delete, e.g. on sign-out) their own doc.
    match /presence/{guideId}/viewers/{uid} {
      allow read: if true;
      allow write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Shared highlights (opt-in, theme.js's highlighting IIFE). Each doc is
    // a highlighted span's position (idx/start/end) plus the owning uid --
    // deliberately NEVER the note text, which stays local-only/private even
    // when shared highlights are on. Doc IDs are client-chosen
    // (`${uid}_${idx}_${start}_${end}`) purely so re-saving the same exact
    // range overwrites instead of duplicating; the *actual* access control
    // is the uid field check below, not the doc ID.
    match /sharedHighlights/{guideId}/marks/{markId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
