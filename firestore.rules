rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write their own synced data --
    // everything else is denied by default. See cloud-sync.js: each
    // localStorage key becomes one doc at users/{uid}/kv/{encodedKey}.
    match /users/{userId}/kv/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
